# La web estática usa docs/js/config.js (no este archivo).
# Copia docs/js/config.example.js → docs/js/config.js y rellena:
#
#   supabaseUrl       → Supabase → Settings → General → Project URL
#   supabaseAnonKey   → Supabase → Settings → API Keys → Publishable key (sb_publishable_...)
#   raffleEndDate     → fecha de cierre del sorteo
#
# Para GitHub Pages, añade estos secrets en el repo (Settings → Secrets → Actions):
#   SUPABASE_URL         → https://xxxxx.supabase.co  (sin /rest/v1/)
#   SUPABASE_ANON_KEY    → sb_publishable_...  (NO uses sb_secret_...)
#
# Opcional (Settings → Secrets → Actions → Variables):
#   RAFFLE_END_DATE      → 2026-06-18T23:59:59+02:00
